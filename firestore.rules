rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null;
    }

    // 1. Museumzalen
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // 2. Kunstwerken
    match /artworks/{artworkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Forum & Community
    match /forum/{postId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // 4. Instellingen
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Story Layouts
    match /stories/{storyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 6. Activiteitslogs (Alleen schrijven voor publiek, lezen voor admin)
    match /activity_logs/{logId} {
      allow create: if true;
      allow read: if isAdmin(); 
    }

    // 7. Gebruikersprofielen
    match /users/{userId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && request.auth.uid == userId;
    }

    // 8. Gedeelde kamers
    match /shared_rooms/{roomId} {
      allow read: if true;
      allow create: if true;
    }

    // 9. Privé Archief
    match /privatePhotos/{photoId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // 10. Mail & Orders
    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // Default: Alles weigeren
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
