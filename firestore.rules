
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if true;
    }
    match /artworks/{artworkId} {
      allow read: if true;
      allow write: if true;
    }
    match /shared_rooms/{roomId} {
      allow read: if true;
      allow write: if true;
    }
    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }
    match /mail/{mailId} {
      allow create: if true;
    }
    match /orders/{orderId} {
      allow read, create: if true;
    }
  }
}
