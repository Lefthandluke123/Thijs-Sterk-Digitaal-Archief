rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is de gebruiker een geautoriseerde beheerder?
    // In dit prototype gebruiken we een simpele check of de gebruiker is ingelogd
    // voor schrijfbevoegdheid op publieke collecties.
    function isAuthenticated() {
      return request.auth != null;
    }

    // 1. Publieke Collecties: Iedereen mag lezen (get + list), alleen admins mogen schrijven.
    
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /artworks/{artworkId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /forum/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /stories/{storyId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /shared_rooms/{roomId} {
      allow read: if true;
      allow create: if true; // Bezoekers kunnen hun eigen kamers aanmaken
      allow update, delete: if isAuthenticated();
    }

    // 2. Beschermde Collecties: Alleen voor Vrienden (ingelogd) of Admins.

    match /privatePhotos/{photoId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 3. Private Systeem Collecties: Alleen schrijven door systeem/bezoeker, lezen door admin.

    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAuthenticated();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read, write: if isAuthenticated();
    }

    // Fallback: Alles wat niet expliciet is gedefinieerd is verboden.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}