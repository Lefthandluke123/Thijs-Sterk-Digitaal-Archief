
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Publieke leesrechten, schrijven alleen voor admin
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /artworks/{artworkId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /monumental_projects/{projectId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /forum/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /stories/{storyId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Tracking: Iedereen mag logs MAKEN, niemand mag ze lezen (behalve admin op papier)
    match /activity_logs/{logId} {
      allow create: if true;
      allow read: if isAuthenticated(); 
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /shared_rooms/{roomId} {
      allow read: if true;
      allow create: if true;
    }

    match /privatePhotos/{photoId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAuthenticated();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read: if isAuthenticated();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
