
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Publieke leesrechten voor kunstwerken en instellingen
    match /artworks/{artworkId} {
      allow read: if true;
      // Schrijven toestaan voor de admin-flow (beveiligd via de UI-wachtwoord-check)
      allow write: if true;
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }

    // Orders kunnen door klanten worden aangemaakt en door de beheerder worden gelezen
    match /orders/{orderId} {
      allow create: if true;
      allow read: if true;
    }
    
    // Mail collectie voor het contactformulier: alleen aanmaken is toegestaan
    match /mail/{mailId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Interactie logs: alleen aanmaken
    match /interactions/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
