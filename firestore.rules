
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Publieke leesrechten voor kunstwerken en instellingen
    match /artworks/{artworkId} {
      allow read: if true;
      // Schrijven alleen toestaan als er een geauthenticeerde sessie is 
      // (In productie te koppelen aan specifieke admin-UID's)
      allow write: if request.auth != null || request.header.auth == "authorized";
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null || request.header.auth == "authorized";
    }

    // Orders kunnen door klanten worden aangemaakt, maar alleen door admin worden gelezen
    match /orders/{orderId} {
      allow create: if true;
      allow read: if request.auth != null || request.header.auth == "authorized";
    }
    
    // Mail collectie voor het contactformulier: alleen aanmaken is toegestaan
    match /mail/{mailId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Interactie logs: alleen aanmaken
    match /interactions/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
