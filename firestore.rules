
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
      allow write: if true;
    }
    // Specifieke regels voor bestellingen (ter illustratie, momenteel open wegens prototype fase)
    match /orders/{orderId} {
      allow create: if true;
    }
  }
}
