
{
  "entities": {
    "Room": {
      "title": "Room",
      "description": "Een thematische zaal in het museum.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug"]
    },
    "Artwork": {
      "title": "Artwork",
      "description": "Een kunstwerk gekoppeld aan meerdere zalen en tags.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "displayTitle": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" },
        "roomIds": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "year": { "type": "string" },
        "medium": { "type": "string" },
        "description": { "type": "string" },
        "brightness": { "type": "number" },
        "featured": { "type": "boolean" },
        "inShop": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "image"]
    },
    "StoryPage": {
      "title": "StoryPage",
      "description": "Een dynamische pagina met rijke layout (DTP-stijl).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "blocks": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["text", "image", "heading"] },
              "content": { "type": "string" },
              "imageUrl": { "type": "string" },
              "layout": { "type": "string", "enum": ["full", "left", "right"] },
              "style": { "type": "object" }
            }
          }
        }
      }
    },
    "Tag": {
      "title": "Tag",
      "description": "Geregistreerde metadata tag.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "usageCount": { "type": "number" }
      }
    }
  },
  "auth": { "providers": ["google"] },
  "firestore": {
    "/rooms/{roomId}": { "schema": "Room", "description": "Museumzalen" },
    "/artworks/{artworkId}": { "schema": "Artwork", "description": "Kunstwerken met multi-room support" },
    "/tags/{tagId}": { "schema": "Tag", "description": "Geregistreerde tags" },
    "/stories/{storyId}": { "schema": "StoryPage", "description": "Rijke content pagina's" },
    "/settings/site": { "schema": "Settings", "description": "Website configuratie" }
  }
}
