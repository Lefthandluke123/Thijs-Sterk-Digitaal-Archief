
{
  "entities": {
    "Room": {
      "title": "Room",
      "description": "Een thematische zaal in het museum.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug"]
    },
    "Artwork": {
      "title": "Artwork",
      "description": "Een kunstwerk gekoppeld aan meerdere zalen en tags.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "displayTitle": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" },
        "roomIds": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "year": { "type": "string" },
        "medium": { "type": "string" },
        "description": { "type": "string" },
        "brightness": { "type": "number" },
        "featured": { "type": "boolean" },
        "inShop": { "type": "boolean" },
        "isMonumental": { "type": "boolean" },
        "monumentalProjectId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "image"]
    },
    "MonumentalProject": {
      "title": "MonumentalProject",
      "description": "Een specifiek monumentaal project (wandkunst, glas-in-lood).",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Onzichtbare registratie van gebruikersacties inclusief geografische data en IP.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["page_view", "artwork_view", "interaction", "auth"] },
        "path": { "type": "string" },
        "targetId": { "type": "string" },
        "targetTitle": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "sessionId": { "type": "string" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "ip": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": { "providers": ["google", "password"] },
  "firestore": {
    "/rooms/{roomId}": { "schema": "Room", "description": "Museumzalen" },
    "/artworks/{artworkId}": { "schema": "Artwork", "description": "Kunstwerken" },
    "/monumental_projects/{projectId}": { "schema": "MonumentalProject", "description": "Monumentale Projecten" },
    "/forum/{postId}": { "schema": "ForumPost", "description": "Community berichten" },
    "/activity_logs/{logId}": { "schema": "ActivityLog", "description": "Gedetailleerde gebruikers-tracking" },
    "/settings/site": { "schema": "Settings", "description": "Website configuratie" },
    "/users/{userId}": { "schema": "UserProfile", "description": "Gebruikersprofielen voor Vrienden" }
  }
}
