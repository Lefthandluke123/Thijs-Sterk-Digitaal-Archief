
{
  "entities": {
    "Room": {
      "title": "Room",
      "description": "Een thematische zaal in het museum.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "slug"]
    },
    "Artwork": {
      "title": "Artwork",
      "description": "Een kunstwerk gekoppeld aan een zaal via roomSlug.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" },
        "roomSlug": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "year": { "type": "string" },
        "medium": { "type": "string" },
        "description": { "type": "string" },
        "brightness": { "type": "number" },
        "cropTop": { "type": "number" },
        "cropBottom": { "type": "number" },
        "cropLeft": { "type": "number" },
        "cropRight": { "type": "number" },
        "featured": { "type": "boolean" },
        "inShop": { "type": "boolean" },
        "audioUrls": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "image", "roomSlug"]
    },
    "Page": {
      "title": "Page",
      "description": "Een dynamische storytelling pagina (bijv. biografieën).",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "sections": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["text", "image", "quote", "gallery"] },
              "content": { "type": "string" },
              "imageUrl": { "type": "string" },
              "caption": { "type": "string" }
            }
          }
        }
      }
    },
    "Settings": {
      "title": "Settings",
      "description": "Website configuratie en alle dynamische teksten.",
      "type": "object",
      "properties": {
        "siteTitle": { "type": "string" },
        "siteSubtitle": { "type": "string" },
        "logoUrl": { "type": "string" },
        "adminEmail": { "type": "string" },
        "stripeEnabled": { "type": "boolean" },
        "stripeSecretKey": { "type": "string" }
      }
    }
  },
  "auth": { "providers": ["google"] },
  "firestore": {
    "/rooms/{roomId}": { "schema": "Room", "description": "Collectie van alle museumzalen" },
    "/artworks/{artworkId}": { "schema": "Artwork", "description": "Collectie van alle kunstwerken" },
    "/pages/{pageId}": { "schema": "Page", "description": "Dynamische content pagina's" },
    "/settings/site": { "schema": "Settings", "description": "Algemene instellingen en vertalingen" }
  }
}
