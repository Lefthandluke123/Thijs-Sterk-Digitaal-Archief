
{
  "entities": {
    "Artwork": {
      "title": "Artwork",
      "description": "Een kunstwerk in het portfolio van de artiest. Openbaar leesbaar voor alle bezoekers.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "De interne titel of bestandsnaam van het schilderij"
        },
        "displayTitle": {
          "type": "string",
          "description": "De titel die aan het publiek wordt getoond in de zalen"
        },
        "series": {
          "type": "string",
          "description": "De collectie of serie waar het bij hoort"
        },
        "year": {
          "type": "string",
          "description": "Het jaar van creatie"
        },
        "medium": {
          "type": "string",
          "description": "Het gebruikte materiaal (bijv. Olieverf, Digitaal)"
        },
        "dimensions": {
          "type": "string",
          "description": "De afmetingen van het werk (bijv. 50x60 cm)"
        },
        "description": {
          "type": "string",
          "description": "Een beschrijving van het werk"
        },
        "imageUrl": {
          "type": "string",
          "description": "URL naar de afbeelding"
        },
        "imageHint": {
          "type": "string",
          "description": "Keywords voor zoekmachines"
        },
        "fileSize": {
          "type": "number",
          "description": "Grootte van het bestand in bytes"
        },
        "fileType": {
          "type": "string",
          "description": "MIME-type van het bestand (bijv. image/jpeg)"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags voor filtering (bijv. Atmosferisch, Geometrisch)"
        },
        "cropTop": {
          "type": "number",
          "description": "Percentage crop aan de bovenkant"
        },
        "cropBottom": {
          "type": "number",
          "description": "Percentage crop aan de onderkant"
        },
        "cropLeft": {
          "type": "number",
          "description": "Percentage crop aan de linkerkant"
        },
        "cropRight": {
          "type": "number",
          "description": "Percentage crop aan de rechterkant"
        },
        "brightness": {
          "type": "number",
          "description": "Helderheid factor (1.0 is standaard)"
        },
        "featured": {
          "type": "boolean",
          "description": "Of dit werk op de voorpagina moet verschijnen"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Tijdstip van toevoegen"
        }
      },
      "required": [
        "title",
        "series",
        "imageUrl"
      ]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "Een interactie van een bezoeker.",
      "type": "object",
      "properties": {
        "visitorId": {
          "type": "string",
          "description": "Unieke persistent ID van de bezoeker"
        },
        "type": {
          "type": "string",
          "enum": ["view_artwork", "filter_tags"],
          "description": "Het type interactie"
        },
        "artworkId": {
          "type": "string",
          "description": "ID van het bekeken kunstwerk"
        },
        "artworkTitle": {
          "type": "string",
          "description": "Titel van het bekeken kunstwerk"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "De geselecteerde filters"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Tijdstip van de interactie"
        }
      }
    },
    "Settings": {
      "title": "Settings",
      "description": "Algemene website instellingen en teksten. Bevat vertalingen voor EN, DE, FR en ES.",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "siteTitle": { "type": "string" },
        "homeHeroTitle": { "type": "string" },
        "homeHeroTitle_en": { "type": "string" },
        "homeHeroTitle_de": { "type": "string" },
        "homeHeroTitle_fr": { "type": "string" },
        "homeHeroTitle_es": { "type": "string" },
        "homeHeroIntro": { "type": "string" },
        "homeHeroIntro_en": { "type": "string" },
        "homeHeroIntro_de": { "type": "string" },
        "homeHeroIntro_fr": { "type": "string" },
        "homeHeroIntro_es": { "type": "string" },
        "homeBioTitle": { "type": "string" },
        "homeBioTitle_en": { "type": "string" },
        "homeBioTitle_de": { "type": "string" },
        "homeBioTitle_fr": { "type": "string" },
        "homeBioTitle_es": { "type": "string" },
        "homeBio": { "type": "string" },
        "homeBio_en": { "type": "string" },
        "homeBio_de": { "type": "string" },
        "homeBio_fr": { "type": "string" },
        "homeBio_es": { "type": "string" },
        "homeBioImageUrl": { "type": "string" },
        "hannekeBio": { "type": "string" },
        "hannekeBio_en": { "type": "string" },
        "hannekeBio_de": { "type": "string" },
        "hannekeBio_fr": { "type": "string" },
        "hannekeBio_es": { "type": "string" },
        "hannekeBioImages": { "type": "array", "items": { "type": "string" } },
        "beatrijsBio": { "type": "string" },
        "beatrijsBio_en": { "type": "string" },
        "beatrijsBio_de": { "type": "string" },
        "beatrijsBio_fr": { "type": "string" },
        "beatrijsBio_es": { "type": "string" },
        "beatrijsBioImages": { "type": "array", "items": { "type": "string" } },
        "peterBesBio": { "type": "string" },
        "peterBesBio_en": { "type": "string" },
        "peterBesBio_de": { "type": "string" },
        "peterBesBio_fr": { "type": "string" },
        "peterBesBio_es": { "type": "string" },
        "peterBesBioImages": { "type": "array", "items": { "type": "string" } },
        "leoDuppenBio": { "type": "string" },
        "leoDuppenBio_en": { "type": "string" },
        "leoDuppenBio_de": { "type": "string" },
        "leoDuppenBio_fr": { "type": "string" },
        "leoDuppenBio_es": { "type": "string" },
        "leoDuppenBioImages": { "type": "array", "items": { "type": "string" } },
        "contactTitle": { "type": "string" },
        "contactTitle_en": { "type": "string" },
        "contactTitle_de": { "type": "string" },
        "contactTitle_fr": { "type": "string" },
        "contactTitle_es": { "type": "string" },
        "contactIntro": { "type": "string" },
        "contactIntro_en": { "type": "string" },
        "contactIntro_de": { "type": "string" },
        "contactIntro_fr": { "type": "string" },
        "contactIntro_es": { "type": "string" },
        "contactQuote": { "type": "string" },
        "contactQuote_en": { "type": "string" },
        "contactQuote_de": { "type": "string" },
        "contactQuote_fr": { "type": "string" },
        "contactQuote_es": { "type": "string" },
        "contactLabelName": { "type": "string" },
        "contactLabelEmail": { "type": "string" },
        "contactLabelSubject": { "type": "string" },
        "contactLabelMessage": { "type": "string" },
        "contactButtonSend": { "type": "string" },
        "hiddenSeries": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": [
      "google"
    ]
  },
  "firestore": {
    "/artworks/{artworkId}": {
      "schema": "Artwork",
      "description": "Collectie van alle kunstwerken"
    },
    "/interactions/{interactionId}": {
      "schema": "Interaction",
      "description": "Log van bezoekersinteracties"
    },
    "/settings/site": {
      "schema": "Settings",
      "description": "Website configuratie en teksten"
    }
  }
}
