
{
  "entities": {
    "Room": {
      "title": "Room",
      "description": "Een thematische zaal in het museum.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug"]
    },
    "Artwork": {
      "title": "Artwork",
      "description": "Een kunstwerk gekoppeld aan meerdere zalen en tags.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "displayTitle": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" },
        "roomIds": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "year": { "type": "string" },
        "medium": { "type": "string" },
        "description": { "type": "string" },
        "brightness": { "type": "number" },
        "featured": { "type": "boolean" },
        "inShop": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "image"]
    },
    "ForumPost": {
      "title": "ForumPost",
      "description": "Een bericht in de community sectie.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "category": { "type": "string", "enum": ["Verhaal", "Vraag", "Ruil/Koop"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "authorId", "category"]
    }
  },
  "auth": { "providers": ["google"] },
  "firestore": {
    "/rooms/{roomId}": { "schema": "Room", "description": "Museumzalen" },
    "/artworks/{artworkId}": { "schema": "Artwork", "description": "Kunstwerken met multi-room support" },
    "/forum/{postId}": { "schema": "ForumPost", "description": "Community berichten" },
    "/settings/site": { "schema": "Settings", "description": "Website configuratie" }
  }
}
