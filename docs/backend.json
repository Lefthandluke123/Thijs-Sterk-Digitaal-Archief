
{
  "entities": {
    "Room": {
      "title": "Room",
      "description": "Een thematische zaal in het museum.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "slug"]
    },
    "Artwork": {
      "title": "Artwork",
      "description": "Een kunstwerk gekoppeld aan een zaal via roomSlug.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" },
        "roomSlug": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "year": { "type": "string" },
        "medium": { "type": "string" },
        "description": { "type": "string" },
        "brightness": { "type": "number" },
        "cropTop": { "type": "number" },
        "cropBottom": { "type": "number" },
        "cropLeft": { "type": "number" },
        "cropRight": { "type": "number" },
        "featured": { "type": "boolean" },
        "inShop": { "type": "boolean" },
        "audioUrls": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "image", "roomSlug"]
    },
    "SharedRoom": {
      "title": "SharedRoom",
      "description": "Een door een gebruiker samengestelde expositie.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "artworkIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "lang": { "type": "string" }
      }
    },
    "Settings": {
      "title": "Settings",
      "description": "Website configuratie.",
      "type": "object",
      "properties": {
        "siteTitle": { "type": "string" },
        "siteSubtitle": { "type": "string" },
        "logoUrl": { "type": "string" }
      }
    }
  },
  "auth": { "providers": ["google"] },
  "firestore": {
    "/rooms/{roomId}": { "schema": "Room", "description": "Collectie van alle museumzalen" },
    "/artworks/{artworkId}": { "schema": "Artwork", "description": "Collectie van alle kunstwerken" },
    "/shared_rooms/{roomId}": { "schema": "SharedRoom", "description": "Gedeelde exposities" },
    "/settings/site": { "schema": "Settings", "description": "Algemene instellingen" }
  }
}
