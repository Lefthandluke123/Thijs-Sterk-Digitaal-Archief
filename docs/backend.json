
{
  "entities": {
    "Artwork": {
      "title": "Artwork",
      "description": "Een kunstwerk in het portfolio van de artiest. Openbaar leesbaar voor alle bezoekers.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "De interne titel of bestandsnaam van het schilderij"
        },
        "displayTitle": {
          "type": "string",
          "description": "De titel die aan het publiek wordt getoond in de zalen"
        },
        "series": {
          "type": "string",
          "description": "De collectie of serie waar het bij hoort"
        },
        "year": {
          "type": "string",
          "description": "Het jaar van creatie"
        },
        "medium": {
          "type": "string",
          "description": "Het gebruikte materiaal (bijv. Olieverf, Digitaal)"
        },
        "description": {
          "type": "string",
          "description": "Een beschrijving van het werk"
        },
        "imageUrl": {
          "type": "string",
          "description": "URL naar de afbeelding"
        },
        "imageHint": {
          "type": "string",
          "description": "Keywords voor zoekmachines"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags voor filtering (bijv. Atmosferisch, Geometrisch)"
        },
        "cropTop": {
          "type": "number",
          "description": "Percentage crop aan de bovenkant"
        },
        "cropBottom": {
          "type": "number",
          "description": "Percentage crop aan de onderkant"
        },
        "cropLeft": {
          "type": "number",
          "description": "Percentage crop aan de linkerkant"
        },
        "cropRight": {
          "type": "number",
          "description": "Percentage crop aan de rechterkant"
        },
        "brightness": {
          "type": "number",
          "description": "Helderheid factor (1.0 is standaard)"
        },
        "featured": {
          "type": "boolean",
          "description": "Of dit werk op de voorpagina moet verschijnen"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Tijdstip van toevoegen"
        }
      },
      "required": [
        "title",
        "series",
        "imageUrl"
      ]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "Een registratie van een bezoekersactie met persistent ID. Schrijfbaar door bezoekers, leesbaar door admin.",
      "type": "object",
      "properties": {
        "visitorId": {
          "type": "string",
          "description": "Unieke persistent ID van de bezoeker"
        },
        "type": {
          "type": "string",
          "enum": ["view_artwork", "filter_tags"],
          "description": "Het type interactie"
        },
        "artworkId": {
          "type": "string",
          "description": "ID van het bekeken kunstwerk"
        },
        "artworkTitle": {
          "type": "string",
          "description": "Titel van het bekeken kunstwerk"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "De geselecteerde filters"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Tijdstip van de interactie"
        }
      }
    },
    "Settings": {
      "title": "Settings",
      "description": "Algemene website instellingen en teksten. Openbaar leesbaar.",
      "type": "object",
      "properties": {
        "logoUrl": {
          "type": "string",
          "description": "URL naar het website logo"
        },
        "siteTitle": {
          "type": "string",
          "description": "De titel van the website"
        },
        "homeBio": {
          "type": "string",
          "description": "Biografie op de homepagina"
        },
        "homeBioImageUrl": {
          "type": "string",
          "description": "URL naar de afbeelding bij de biografie op home"
        },
        "hannekeBio": {
          "type": "string",
          "description": "Biografie van Hanneke Sterk"
        },
        "hannekeBioImages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lijst van afbeeldings-URLs voor Hanneke"
        },
        "beatrijsBio": {
          "type": "string",
          "description": "Biografie van Beatrijs Sterk"
        },
        "beatrijsBioImages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lijst van afbeeldings-URLs voor Beatrijs"
        },
        "peterBesBio": {
          "type": "string",
          "description": "Biografie van Peter Bes"
        },
        "peterBesBioImages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lijst van afbeeldings-URLs voor Peter Bes"
        },
        "leoDuppenBio": {
          "type": "string",
          "description": "Biografie van Leo Duppen"
        },
        "leoDuppenBioImages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lijst van afbeeldings-URLs voor Leo Duppen"
        },
        "hiddenSeries": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lijst van zalen die verborgen zijn voor publiek"
        }
      }
    }
  },
  "auth": {
    "providers": [
      "google"
    ]
  },
  "firestore": {
    "/artworks/{artworkId}": {
      "schema": "Artwork",
      "description": "Collectie van alle kunstwerken"
    },
    "/interactions/{interactionId}": {
      "schema": "Interaction",
      "description": "Log van bezoekersinteracties"
    },
    "/settings/site": {
      "schema": "Settings",
      "description": "Website configuratie en teksten"
    }
  }
}
